# ---- CLIENT (client/.env locally, or Vercel env vars in prod) ----

# Spotify app client ID — https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Socket.io backend URL
#   local:  http://localhost:3001
#   prod:   https://<your-backend>.onrender.com
VITE_SOCKET_URL=http://localhost:3001

# NOTE: the Spotify redirect URI is derived automatically from the current
# origin (`window.location.origin + /callback`). Just register BOTH of these
# in the Spotify dashboard:
#   http://127.0.0.1:5173/callback        (local dev)
#   https://<your-app>.vercel.app/callback (production)


# ---- SERVER (server/.env locally, or Render env vars in prod) ----

# Render provides PORT automatically; locally defaults to 3001
PORT=3001

# Allowed CORS origin (the client URL)
#   local:  http://127.0.0.1:5173
#   prod:   https://<your-app>.vercel.app
CLIENT_URL=http://127.0.0.1:5173
